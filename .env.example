# ============================================================
#  shopify-stripe-checkout — Environment Variables
# ============================================================
#  Copy to ".env.local" for local dev, and set the SAME keys in
#  Vercel → Project → Settings → Environment Variables.
#  NEVER commit real values. .env.local is git-ignored.
# ------------------------------------------------------------

# === STRIPE (use TEST keys: pk_test_... / sk_test_...) ===
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Webhook signing secret from Stripe Dashboard → Developers
# → Webhooks (whsec_...), after creating the endpoint.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === SHOPIFY ===
SHOPIFY_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-01

# === STOREFRONT ===
# Where Stripe returns the customer (success/cancel) and which
# origins may call the API (CORS).
STORE_URL=https://your-store.example
ALLOWED_ORIGINS=https://your-store.example,https://your-store.myshopify.com

# Currency for the Stripe Checkout Session (lowercase ISO).
CURRENCY=eur
